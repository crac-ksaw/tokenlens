{
  "name": "tokenlens",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.8.1",
  "scripts": {
    "build": "corepack pnpm -r build",
    "test": "corepack pnpm -r test",
    "typecheck": "corepack pnpm -r typecheck",
    "dev": "corepack pnpm --parallel --filter @tokenlens/api --filter @tokenlens/worker --filter @tokenlens/web dev",
    "db:migrate": "tsx scripts/run-migrations.ts",
    "db:seed": "tsx scripts/seed.ts"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.15.3",
    "@types/pg": "^8.15.5",
    "pg": "^8.16.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3"
  }
}
